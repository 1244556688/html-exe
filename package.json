{
  "name": "myapp",
  "version": "1.0.0",
  "author": "1244556688",
  "description": "My Electron App",
  "main": "main.js",

  "repository": {
    "type": "git",
    "url": "https://github.com/1244556688/html-exe.git"
  },

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
