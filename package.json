{
  "name": "myapp",
  "version": "1.0.0",
  "author": "Your Name",
  "description": "My Electron App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^38.8.6",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.myapp.desktop",
    "productName": "MyApp",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github"
      }
    ]
  }
}
