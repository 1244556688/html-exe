{
  "name": "myapp",
  "version": "1.0.0",
  "author": "1244556688",
  "main": "main.js",
  "description": "Beautiful Electron App",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },

  "devDependencies": {
    "electron": "^38.8.6",
    "electron-builder": "^26.15.2",
    "png-to-ico": "^2.1.0"
  },

  "build": {
    "appId": "com.myapp.desktop",
    "productName": "MyApp",

    "directories": {
      "output": "dist"
    },

    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    }
  }
}
