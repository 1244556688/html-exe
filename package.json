{
  "name": "myapp",
  "version": "1.0.0",
  "description": "My Electron App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.myapp.desktop",
    "productName": "MyApp",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
      {
  "build": {
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    }
  }
}
